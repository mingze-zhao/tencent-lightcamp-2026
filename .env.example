ASR_PROVIDER=faster_whisper
ASR_LANGUAGE=yue
TRANSCRIPT_SCRIPT=traditional
MAX_UPLOAD_MB=50
WHISPER_MODEL=small
WHISPER_RECOMMENDED_MODEL=small
WHISPER_ALLOWED_MODELS=tiny,base,small,medium,large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=5
WHISPER_VAD_FILTER=true
WHISPER_INITIAL_PROMPT=以下是香港社工家访场景的粤语对话，请尽量输出繁体中文，并保留常见药名、身体症状与英文专有名词，例如头晕、脚肿、气喘、降压药、Metformin。
